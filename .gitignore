# Root .gitignore for the inference-sim-platform (extension) module.
# The vendored base keeps its own .gitignore under third_party/inference-sim/.
# NOTE: data/ is intentionally NOT ignored here — curated seed files are tracked.

# Go build artifacts
/apiserver-bin
/apiserver.bin
*.exe
*.test
*.out
coverage.*

# Go workspace
go.work
go.work.sum

# Frontend (web/ also has its own .gitignore)
node_modules/
web/dist/
.vite/

# Editor / OS
.DS_Store
*.bak
*.swp

# Local env
.env
